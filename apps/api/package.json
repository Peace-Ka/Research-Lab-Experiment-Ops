{
    "name":  "@labops/api",
    "version":  "0.1.0",
    "private":  true,
    "scripts":  {
                    "build":  "tsc -p tsconfig.build.json",
                    "start":  "node dist/apps/api/src/main.js",
                    "start:dev":  "ts-node --project tsconfig.json -r tsconfig-paths/register src/main.ts",
                    "start:watch":  "node --watch --require ts-node/register --require tsconfig-paths/register src/main.ts",
                    "lint":  "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
                    "test":  "jest --config ./test/jest-unit.json --passWithNoTests --runInBand",
                    "test:e2e":  "jest --config ./test/jest-e2e.json --runInBand",
                    "prisma:generate":  "prisma generate --schema ../../prisma/schema.prisma",
                    "prisma:migrate":  "prisma migrate dev --schema ../../prisma/schema.prisma",
                    "prisma:seed":  "npm run prisma:seed:safe",
                    "prisma:seed:safe":  "ts-node --project tsconfig.json ../../prisma/seed.ts --mode=safe",
                    "prisma:seed:reset":  "ts-node --project tsconfig.json ../../prisma/seed.ts --mode=reset"
                },
    "dependencies":  {
                         "@clerk/backend":  "^3.2.0",
                         "@nestjs/common":  "^11.0.0",
                         "@nestjs/config":  "^4.0.2",
                         "@nestjs/core":  "^11.0.0",
                         "@nestjs/platform-express":  "^11.0.0",
                         "@prisma/client":  "^6.5.0",
                         "class-transformer":  "^0.5.1",
                         "class-validator":  "^0.14.1",
                         "reflect-metadata":  "^0.2.2",
                         "rxjs":  "^7.8.1"
                     },
    "devDependencies":  {
                            "@nestjs/cli":  "^11.0.0",
                            "@nestjs/schematics":  "^11.0.0",
                            "@nestjs/testing":  "^11.0.0",
                            "@types/express":  "^5.0.1",
                            "@types/jest":  "^29.5.14",
                            "@types/node":  "^22.13.10",
                            "@types/supertest":  "^6.0.3",
                            "eslint":  "^9.21.0",
                            "eslint-config-prettier":  "^10.0.2",
                            "jest":  "^29.7.0",
                            "prettier":  "^3.5.2",
                            "prisma":  "^6.5.0",
                            "supertest":  "^7.0.0",
                            "ts-jest":  "^29.2.6",
                            "ts-node":  "^10.9.2",
                            "tsconfig-paths":  "^4.2.0",
                            "typescript":  "^5.8.2"
                        }
}