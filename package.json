{
    "name":  "research-lab-experiment-ops",
    "private":  true,
    "version":  "0.1.0",
    "workspaces":  [
                       "apps/*",
                       "packages/*"
                   ],
    "scripts":  {
                    "build":  "npm run build --workspace @labops/api",
                    "dev":  "npm run start:dev --workspace @labops/api",
                    "lint":  "npm run lint --workspace @labops/api",
                    "test":  "npm run test --workspace @labops/api",
                    "test:integration":  "npm run test:e2e --workspace @labops/api",
                    "test:all":  "npm run test \u0026\u0026 npm run test:integration",
                    "docker:up":  "docker compose -f infra/docker/docker-compose.dev.yml up -d",
                    "docker:down":  "docker compose -f infra/docker/docker-compose.dev.yml down",
                    "prisma:generate":  "npm run prisma:generate --workspace @labops/api",
                    "prisma:migrate":  "npm run prisma:migrate --workspace @labops/api",
                    "prisma:seed":  "npm run prisma:seed:safe --workspace @labops/api",
                    "web:dev":  "npm run dev --workspace @labops/web",
                    "web:build":  "npm run build --workspace @labops/web",
                    "prisma:seed:safe":  "npm run prisma:seed:safe --workspace @labops/api",
                    "prisma:seed:reset":  "npm run prisma:seed:reset --workspace @labops/api"
                },
    "engines":  {
                    "node":  "\u003e=22"
                }
}